# --- Секреты и конфигурация окружения ---
.env
.env.*
!.env.example

# --- Зависимости ---
# Игнорируем папки с зависимостями, так как они устанавливаются менеджерами пакетов.
/backend/.venv/
/pipgraph-obsidian/node_modules/
/pipgraph-web/node_modules/
/pipgraph-cli/.venv/

# --- Python ---
# Игнорируем кэш и временные файлы, создаваемые Python.
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.tox/
.coverage

# --- JavaScript / TypeScript / Frontend ---
# Игнорируем логи, временные файлы и папки сборки.
/pipgraph-web/.next/
/pipgraph-web/out/
/pipgraph-obsidian/main.js
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- Локальные базы данных ---
# Игнорируем файлы локальных баз данных, которые могут использоваться для тестирования.
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3

# Данные Neo4j Desktop обычно хранятся вне папки проекта, но если вы
# создаете локальные дампы или файлы, добавьте их сюда.
# Например:
# /database_dumps/

# --- Файлы операционной системы ---
# Игнорируем системные файлы, которые создаются автоматически.
.DS_Store
._*
Thumbs.db

# --- Файлы IDE и редакторов кода ---
# У каждого разработчика могут быть свои настройки IDE.
.idea/
.vscode/
*.swp
*.swo

# --- Логи и временные файлы ---
# Общие папки и файлы для логов.
logs/
*.log
tmp/
temp/

# --- Локальные рабочие заметки ---
# Папка для временной документации и анализа задач.
/backend/TODO/

.pres
.docs